<Window x:Class="DustFinder.Plugin.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:controls="clr-namespace:DustFinder.Plugin.Controls"
        Title="DustFinder · Collection and dust planner"
        Width="1280" Height="820" MinWidth="920" MinHeight="620"
        WindowStartupLocation="CenterScreen"
        Background="#15171C" Foreground="#E8EAF0">
    <Window.Resources>
        <SolidColorBrush x:Key="PanelBrush" Color="#20232A" />
        <SolidColorBrush x:Key="BorderBrush" Color="#343944" />
        <SolidColorBrush x:Key="AccentBrush" Color="#4DA3FF" />
		<DataTemplate x:Key="CardPreviewTemplate">
			<StackPanel HorizontalAlignment="Center">
				<TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" TextAlignment="Center"
						   TextWrapping="Wrap" Margin="6,8,6,4" />
				<controls:BindableCardImage BoundCardId="{Binding CardId}" Width="220" Height="310"
									HorizontalAlignment="Center" />
				<TextBlock Text="{Binding Expansion}" Foreground="#AEB5C2" TextAlignment="Center"
						   TextWrapping="Wrap" Margin="6,4,6,8" />
			</StackPanel>
		</DataTemplate>
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="#E8EAF0" />
        </Style>
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Background" Value="#2E6FAE" />
            <Setter Property="BorderBrush" Value="#4DA3FF" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="TextBox">
            <Setter Property="Foreground" Value="#F4F5F7" />
            <Setter Property="Background" Value="#252932" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="#17191E" />
            <Setter Property="Background" Value="#ECEFF4" />
            <Setter Property="Padding" Value="5,3" />
            <Setter Property="Margin" Value="3" />
        </Style>
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#E8EAF0" />
            <Setter Property="Margin" Value="5" />
        </Style>
        <Style TargetType="TabItem">
            <Setter Property="Foreground" Value="#15171C" />
            <Setter Property="Padding" Value="14,7" />
        </Style>
        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="#1B1E24" />
            <Setter Property="Foreground" Value="#E8EAF0" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#303540" />
            <Setter Property="RowBackground" Value="#1B1E24" />
            <Setter Property="AlternatingRowBackground" Value="#22262E" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="CanUserSortColumns" Value="True" />
            <Setter Property="CanUserResizeColumns" Value="True" />
            <Setter Property="IsReadOnly" Value="True" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="SelectionMode" Value="Single" />
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#292D36" />
            <Setter Property="Foreground" Value="#F4F5F7" />
            <Setter Property="Padding" Value="6" />
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <DockPanel>
				<StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
					<Button x:Name="UpdateCheckButton" Content="{Binding UpdateActionText}" Command="{Binding UpdateCommand}"
							ToolTip="Check the latest GitHub Release, or download its versioned DustFinder ZIP when an update is available." />
					<Button Content="Refresh collection" Command="{Binding RefreshCommand}"
							ToolTip="Asks HDT to read the collection for the Hearthstone account that is currently signed in." />
				</StackPanel>
				<StackPanel>
					<StackPanel Orientation="Horizontal">
						<TextBlock Text="DustFinder" FontSize="24" FontWeight="SemiBold" />
						<TextBlock x:Name="PluginVersionText" FontSize="13"
								   Foreground="#AEB5C2" Margin="8,0,0,3" VerticalAlignment="Bottom" />
					</StackPanel>
					<TextBlock Text="{Binding AccountLabel}" Foreground="#AEB5C2" Margin="0,3,0,0" />
					<TextBlock x:Name="UpdateStatusText" Text="{Binding UpdateStatus}" Foreground="#8FC7FF"
							   TextWrapping="Wrap" Margin="0,3,0,0" />
				</StackPanel>
            </DockPanel>
        </Border>

        <TabControl Grid.Row="1" Background="#1B1E24" BorderBrush="{StaticResource BorderBrush}">
            <TabItem Header="Collection">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" Margin="0,0,0,6">
                        <StackPanel>
                            <TextBlock Text="Search" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <TextBox Width="235" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="Searches card name, expansion, mechanic, tribe, type, class, card ID, and card text." />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Expansion" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <ComboBox x:Name="ExpansionFilter" Width="220" ItemsSource="{Binding Expansions}"
                                      SelectedItem="{Binding SelectedExpansion, Mode=TwoWay}" SelectedIndex="0" ToolTip="Expansion" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Rarity" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <ComboBox Width="115" ItemsSource="{Binding Rarities}" SelectedItem="{Binding SelectedRarity}" ToolTip="Rarity" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Class" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <ComboBox x:Name="ClassFilter" Width="135" ItemsSource="{Binding Classes}"
                                      SelectedItem="{Binding SelectedClass, Mode=TwoWay}" SelectedIndex="0" ToolTip="Class" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Format" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <ComboBox Width="115" ItemsSource="{Binding Formats}" SelectedItem="{Binding SelectedFormat}" ToolTip="Standard or Wild" />
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Premium" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
                            <ComboBox Width="120" ItemsSource="{Binding Premiums}" SelectedItem="{Binding SelectedPremium}" ToolTip="Normal, Golden, Signature, or Diamond" />
                        </StackPanel>
                    </WrapPanel>
					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
                    <DataGrid x:Name="CollectionGrid" Grid.Column="0" ItemsSource="{Binding CardsView}"
                              SelectedItem="{Binding SelectedCard}" AlternationCount="2"
                              SelectionMode="Extended" SelectionUnit="FullRow"
							  HorizontalScrollBarVisibility="Auto"
							  SelectionChanged="CollectionGrid_OnSelectionChanged"
							  Sorting="DataGrid_OnSorting">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="200" />
                            <DataGridTextColumn Header="Expansion" Binding="{Binding Expansion}" Width="SizeToCells" MinWidth="140" MaxWidth="220" />
                            <DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="85" MinWidth="70" />
                            <DataGridTextColumn Header="Class" Binding="{Binding CardClass}" Width="150" MinWidth="110" />
                            <DataGridTextColumn Header="Type" Binding="{Binding CardType}" Width="95" />
							<DataGridTextColumn Header="Premium" Binding="{Binding Premium}" SortMemberPath="PremiumSortOrder" Width="90" MinWidth="75" />
							<DataGridTextColumn Header="Owned" Binding="{Binding Owned}" Width="65" />
							<DataGridTextColumn Header="Deck max" Binding="{Binding DeckMax}" Width="75" />
                            <DataGridTextColumn Header="Keep" Binding="{Binding Keep}" Width="55" />
                            <DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="55" MinWidth="45" />
                            <DataGridTextColumn Header="Dust ea." Binding="{Binding DustEach}" Width="70" />
                            <DataGridTextColumn Header="Potential" Binding="{Binding PotentialDust}" Width="75" MinWidth="65" />
                            <DataGridTextColumn Header="Assessment" Binding="{Binding Safety}" Width="175" MinWidth="150" />
                        </DataGrid.Columns>
                    </DataGrid>
						<Border x:Name="CollectionCardPreview" Grid.Column="1" Width="245" Margin="8,0,0,0"
								Background="#171A20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
							<ContentControl Content="{Binding SelectedCard}" ContentTemplate="{StaticResource CardPreviewTemplate}" />
						</Border>
					</Grid>
                    <DockPanel Grid.Row="2" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
							<Button x:Name="CopyCardNameButton" Content="Copy name" Command="{Binding CopyNameCommand}"
									ToolTip="Copy the selected card's exact name for pasting into Hearthstone search." />
                            <Button Content="Add selected to plan" Command="{Binding AddSelectedCommand}"
                                    ToolTip="Select multiple rows with Ctrl or Shift, then add one copy of each selected card." />
                            <Button Content="Protect selected" Command="{Binding ProtectCommand}"
                                    ToolTip="Select multiple rows with Ctrl or Shift, then protect all selected cards." />
							<Button x:Name="MarkUncraftableButton" Content="Mark uncraftable" Command="{Binding MarkUncraftableCommand}"
									ToolTip="Mark each selected premium variant as uncraftable, remove it from Collection, and include it in the JSON report." />
                        </StackPanel>
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock x:Name="CollectionCountText" Text="{Binding CollectionCountLabel}" FontWeight="SemiBold" Margin="0,0,18,0" />
							<TextBlock Foreground="#AEB5C2"
									   Text="Hold Ctrl or Shift to select multiple rows. Only pasted decks provide automatic deck protection."
									   ToolTip="DustFinder only calls copies extra after the configured keep rules are satisfied." />
						</StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Dust planner">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <WrapPanel Grid.Row="0" VerticalAlignment="Center">
                        <TextBlock Text="Target dust" VerticalAlignment="Center" Margin="3" />
                        <TextBox Width="100" Text="{Binding TargetDust, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Selected:" VerticalAlignment="Center" Margin="20,0,4,0" />
                        <TextBlock Text="{Binding PlannedDust}" FontWeight="Bold" VerticalAlignment="Center" />
                        <TextBlock Text="Remaining:" VerticalAlignment="Center" Margin="20,0,4,0" />
                        <TextBlock Text="{Binding RemainingDust}" FontWeight="Bold" VerticalAlignment="Center" />
                    </WrapPanel>
					<StackPanel Grid.Row="1" Margin="0,6,0,6">
						<TextBlock x:Name="PlannerCriteriaText" Text="Use only dust-eligible cards matching these criteria"
								   Foreground="#AEB5C2" Margin="4,0,0,2" />
					<WrapPanel>
						<StackPanel>
							<TextBlock Text="Search" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<TextBox Width="235" Text="{Binding PlannerSearchText, UpdateSourceTrigger=PropertyChanged}" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Expansion" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="PlannerExpansionFilter" Width="220" ItemsSource="{Binding Expansions}"
									  SelectedItem="{Binding SelectedPlannerExpansion, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Rarity" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="PlannerRarityFilter" Width="115" ItemsSource="{Binding Rarities}"
									  SelectedItem="{Binding SelectedPlannerRarity, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Class" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="PlannerClassFilter" Width="135" ItemsSource="{Binding Classes}"
									  SelectedItem="{Binding SelectedPlannerClass, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Format" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="PlannerFormatFilter" Width="115" ItemsSource="{Binding Formats}"
									  SelectedItem="{Binding SelectedPlannerFormat, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Premium" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="PlannerPremiumFilter" Width="120" ItemsSource="{Binding Premiums}"
									  SelectedItem="{Binding SelectedPlannerPremium, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<Button x:Name="FindCombinationButton" Content="Find combination" Command="{Binding PlanCommand}"
								VerticalAlignment="Bottom" Margin="8,3,3,3"
								ToolTip="Applies the selected search, expansion, rarity, class, format, and premium criteria before finding the closest dust combination." />
					</WrapPanel>
					</StackPanel>
					<Grid Grid.Row="2">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
                    <DataGrid x:Name="PlanGrid" Grid.Column="0" ItemsSource="{Binding PlanRowsView}" SelectedItem="{Binding SelectedPlanRow}"
							  AlternationCount="2" SelectionMode="Extended" SelectionUnit="FullRow"
							  HorizontalScrollBarVisibility="Auto"
							  SelectionChanged="PlanGrid_OnSelectionChanged" Sorting="DataGrid_OnSorting">
                        <DataGrid.Columns>
							<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="200" />
							<DataGridTextColumn Header="Expansion" Binding="{Binding Expansion}" Width="SizeToCells" MinWidth="140" MaxWidth="220" />
							<DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="85" MinWidth="70" />
							<DataGridTextColumn Header="Class" Binding="{Binding CardClass}" Width="150" MinWidth="110" />
							<DataGridTextColumn Header="Type" Binding="{Binding CardType}" Width="95" />
							<DataGridTextColumn Header="Premium" Binding="{Binding Premium}" SortMemberPath="PremiumSortOrder" Width="90" MinWidth="75" />
							<DataGridTextColumn Header="Owned" Binding="{Binding Owned}" Width="65" />
							<DataGridTextColumn Header="Deck max" Binding="{Binding DeckMax}" Width="75" />
							<DataGridTextColumn Header="Keep" Binding="{Binding Keep}" Width="55" />
							<DataGridTextColumn Header="Extra" Binding="{Binding Extra}" Width="55" MinWidth="45" />
							<DataGridTextColumn Header="Dust ea." Binding="{Binding DustEach}" Width="70" />
							<DataGridTextColumn Header="Potential" Binding="{Binding PotentialDust}" Width="75" MinWidth="65" />
							<DataGridTextColumn Header="Assessment" Binding="{Binding Safety}" Width="175" MinWidth="150" />
							<DataGridTextColumn Header="Plan copies" Binding="{Binding Copies}" Width="85" />
							<DataGridTextColumn Header="Plan dust" Binding="{Binding Total}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
						<Border x:Name="PlanCardPreview" Grid.Column="1" Width="245" Margin="8,0,0,0"
								Background="#171A20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
							<ContentControl Content="{Binding SelectedPlanRow}" ContentTemplate="{StaticResource CardPreviewTemplate}" />
						</Border>
					</Grid>
                    <DockPanel Grid.Row="3" Margin="0,6,0,0">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
							<Button x:Name="CopyPlanCardNameButton" Content="Copy name" Command="{Binding CopyPlanNameCommand}"
									ToolTip="Copy the selected planned card's exact name for pasting into Hearthstone search." />
							<Button Content="Protect selected" Command="{Binding ProtectPlanCommand}"
									ToolTip="Select plan rows with Ctrl or Shift, then protect those cards and remove them from future combinations." />
                            <Button Content="Remove one" Command="{Binding RemovePlanCommand}" />
                            <Button Content="Clear plan" Command="{Binding ClearPlanCommand}" />
                        </StackPanel>
                        <TextBlock Text="Recommendation only — DustFinder never clicks Hearthstone or disenchants cards." VerticalAlignment="Center" Foreground="#F2C66D" />
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Pasted decks">
                <Grid Margin="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock TextWrapping="Wrap" Margin="3,3,3,8" Foreground="#AEB5C2"
                               Text="Paste a Hearthstone deck code or the complete text copied from Hearthstone. Every card in an imported deck is excluded from dust recommendations across all premium variants." />
                    <Grid Grid.Row="1" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="105" AcceptsReturn="True" TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 Text="{Binding PastedDeckText, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="You can paste either only the AAE... deck code or Hearthstone's complete copied deck list." />
                        <Button Grid.Column="1" VerticalAlignment="Bottom" Content="Import deck" Command="{Binding ImportPastedDeckCommand}" />
                    </Grid>
                    <DataGrid Grid.Row="2" ItemsSource="{Binding PastedDecks}" SelectedItem="{Binding SelectedPastedDeck}" AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Deck" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Format" Binding="{Binding Format}" Width="140" />
                            <DataGridTextColumn Header="Unique cards" Binding="{Binding UniqueCards}" Width="110" />
                            <DataGridTextColumn Header="Deck size" Binding="{Binding TotalCards}" Width="100" />
                            <DataGridTextColumn Header="Imported (UTC)" Binding="{Binding ImportedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="155" />
                        </DataGrid.Columns>
                    </DataGrid>
                    <DockPanel Grid.Row="3" Margin="0,6,0,0">
                        <Button DockPanel.Dock="Right" Content="Remove selected deck" Command="{Binding RemovePastedDeckCommand}" />
                        <TextBlock VerticalAlignment="Center" Foreground="#F2C66D"
                                   Text="Removing a deck also removes its protection unless another pasted deck still uses the card." />
                    </DockPanel>
                </Grid>
            </TabItem>

            <TabItem Header="Protected cards">
                <Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<WrapPanel Grid.Row="0" Margin="0,0,0,6">
						<StackPanel>
							<TextBlock Text="Search" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<TextBox Width="235" Text="{Binding ProtectedSearchText, UpdateSourceTrigger=PropertyChanged}" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Expansion" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectedExpansionFilter" Width="220" ItemsSource="{Binding ProtectedExpansions}"
									  SelectedItem="{Binding SelectedProtectedExpansion, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Rarity" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectedRarityFilter" Width="115" ItemsSource="{Binding ProtectedRarities}"
									  SelectedItem="{Binding SelectedProtectedRarity, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Class" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectedClassFilter" Width="180" ItemsSource="{Binding ProtectedClasses}"
									  SelectedItem="{Binding SelectedProtectedClass, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Format" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectedFormatFilter" Width="115" ItemsSource="{Binding ProtectedFormats}"
									  SelectedItem="{Binding SelectedProtectedFormat, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Premium" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectedPremiumFilter" Width="120" ItemsSource="{Binding ProtectedPremiums}"
									  SelectedItem="{Binding SelectedProtectedPremium, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
						<StackPanel>
							<TextBlock Text="Reason" Foreground="#AEB5C2" FontSize="11" Margin="4,0,0,0" />
							<ComboBox x:Name="ProtectionReasonFilter" Width="180" ItemsSource="{Binding ProtectionReasons}"
									  SelectedItem="{Binding SelectedProtectionReason, Mode=TwoWay}" SelectedIndex="0" />
						</StackPanel>
					</WrapPanel>
					<Grid Grid.Row="1">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*" />
							<ColumnDefinition Width="Auto" />
						</Grid.ColumnDefinitions>
					<DataGrid x:Name="ProtectedGrid" Grid.Column="0" ItemsSource="{Binding ProtectedCardsView}" SelectedItem="{Binding SelectedProtectedCard}"
							  AlternationCount="2" HorizontalScrollBarVisibility="Auto"
							  Sorting="DataGrid_OnSorting">
                        <DataGrid.Columns>
							<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="2*" MinWidth="220" />
							<DataGridTextColumn Header="Expansion" Binding="{Binding Expansion}" Width="SizeToCells" MinWidth="140" MaxWidth="220" />
							<DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="85" />
							<DataGridTextColumn Header="Class" Binding="{Binding CardClass}" Width="150" />
							<DataGridTextColumn Header="Premium" Binding="{Binding Premium}" SortMemberPath="PremiumSortOrder" Width="90" />
							<DataGridTextColumn Header="Reason" Binding="{Binding ProtectionReason}" Width="2*" MinWidth="180" />
                        </DataGrid.Columns>
                    </DataGrid>
						<Border x:Name="ProtectedCardPreview" Grid.Column="1" Width="245" Margin="8,0,0,0"
								Background="#171A20" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
							<ContentControl Content="{Binding SelectedProtectedCard}" ContentTemplate="{StaticResource CardPreviewTemplate}" />
						</Border>
					</Grid>
					<DockPanel Grid.Row="2" Margin="0,6,0,0">
                        <Button DockPanel.Dock="Right" Content="Remove protection" Command="{Binding UnprotectCommand}" />
						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
							<TextBlock x:Name="ProtectedCountText" Text="{Binding ProtectedCountLabel}" FontWeight="SemiBold" Margin="0,0,18,0" />
							<TextBlock Foreground="#AEB5C2"
									   Text="Pasted-deck protection is removed in Pasted decks; premium-type and expansion protection are changed in Settings." />
						</StackPanel>
                    </DockPanel>
                </Grid>
            </TabItem>

			<TabItem Header="Uncraftable reports">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto" />
						<RowDefinition Height="*" />
						<RowDefinition Height="Auto" />
					</Grid.RowDefinitions>
					<TextBlock Margin="3,3,3,8" TextWrapping="Wrap" Foreground="#AEB5C2"
							   Text="These are your local variant-specific overrides. They are excluded from Collection and dust recommendations." />
					<DataGrid x:Name="UncraftableReportsGrid" Grid.Row="1" ItemsSource="{Binding ManualUncraftableCards}"
							  SelectedItem="{Binding SelectedManualUncraftableCard}" AlternationCount="2">
						<DataGrid.Columns>
							<DataGridTextColumn Header="Name" Binding="{Binding Name}" Width="*" />
							<DataGridTextColumn Header="Card ID" Binding="{Binding CardId}" Width="145" />
							<DataGridTextColumn Header="DBF ID" Binding="{Binding DbfId}" Width="85" />
							<DataGridTextColumn Header="Expansion" Binding="{Binding Expansion}" Width="210" />
							<DataGridTextColumn Header="Class" Binding="{Binding CardClass}" Width="180" />
							<DataGridTextColumn Header="Rarity" Binding="{Binding Rarity}" Width="95" />
							<DataGridTextColumn Header="Premium" Binding="{Binding Premium}" Width="100" />
							<DataGridTextColumn Header="Reported (UTC)" Binding="{Binding ReportedAtUtc, StringFormat={}{0:yyyy-MM-dd HH:mm}}" Width="145" />
						</DataGrid.Columns>
					</DataGrid>
					<DockPanel Grid.Row="2" Margin="0,6,0,0">
						<StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
							<Button Content="Remove selected override" Command="{Binding RemoveUncraftableCommand}"
									ToolTip="Allow DustFinder to classify this premium variant from metadata again." />
							<Button x:Name="CopyUncraftableJsonButton" Content="Copy JSON" Command="{Binding CopyUncraftableJsonCommand}"
									ToolTip="Copy the complete report to the clipboard so you can paste it into Codex." />
						</StackPanel>
						<TextBlock VerticalAlignment="Center" Foreground="#F2C66D"
								   Text="Overrides are exact per premium variant; marking Golden does not hide Normal." />
					</DockPanel>
				</Grid>
			</TabItem>

            <TabItem Header="Snapshot history">
                <Grid Margin="8">
                    <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
                    <TextBlock TextWrapping="Wrap" Foreground="#F2C66D" Margin="3,3,3,8"
                               Text="This is inferred snapshot history: it compares two collection reads. It is not a guaranteed pack-opening or disenchant log." />
                    <DataGrid Grid.Row="1" ItemsSource="{Binding HistoryRows}" AlternationCount="2">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Card" Binding="{Binding Name}" Width="*" />
                            <DataGridTextColumn Header="Premium" Binding="{Binding Premium}" Width="130" />
                            <DataGridTextColumn Header="Previous" Binding="{Binding Before}" Width="100" />
                            <DataGridTextColumn Header="Current" Binding="{Binding After}" Width="100" />
                            <DataGridTextColumn Header="Change" Binding="{Binding Delta}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Settings">
				<ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
				<StackPanel Margin="18" MaxWidth="760" HorizontalAlignment="Left">
                    <TextBlock Text="Copies to keep" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DockPanel Margin="0,3"><TextBox DockPanel.Dock="Right" Width="90" Text="{Binding Settings.KeepNonLegendary}" /><TextBlock Text="Non-Legendary cards" VerticalAlignment="Center" /></DockPanel>
                    <DockPanel Margin="0,3"><TextBox DockPanel.Dock="Right" Width="90" Text="{Binding Settings.KeepLegendary}" /><TextBlock Text="Legendary cards" VerticalAlignment="Center" /></DockPanel>
					<TextBlock Text="Which premium types should be protected completely?" Margin="0,16,0,5"
							   ToolTip="Checked premium types are hidden from Collection and dust recommendations." />
					<CheckBox Content="Normal" IsChecked="{Binding Settings.ProtectNormalPremium}" />
					<CheckBox Content="Golden" IsChecked="{Binding Settings.ProtectGoldenPremium}" />
					<CheckBox Content="Signature" IsChecked="{Binding Settings.ProtectSignaturePremium}" />
					<CheckBox Content="Diamond" IsChecked="{Binding Settings.ProtectDiamondPremium}" />
					<TextBlock Text="Which expansions should be protected completely?" Margin="0,16,0,5"
							   ToolTip="Every owned card from a checked expansion is hidden from Collection and dust recommendations." />
					<Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" Background="#171A20">
						<ItemsControl x:Name="ExpansionProtectionList" Height="250" ItemsSource="{Binding ExpansionProtectionOptions}">
							<ItemsControl.ItemsPanel>
								<ItemsPanelTemplate>
									<WrapPanel Orientation="Vertical" />
								</ItemsPanelTemplate>
							</ItemsControl.ItemsPanel>
							<ItemsControl.ItemTemplate>
								<DataTemplate>
									<CheckBox Width="235" Margin="2" Content="{Binding Name}" IsChecked="{Binding IsProtected}" />
								</DataTemplate>
							</ItemsControl.ItemTemplate>
						</ItemsControl>
					</Border>
                    <TextBlock Margin="0,14,0,5" TextWrapping="Wrap" Foreground="#AEB5C2"
							   Text="Checked premium types and expansions are protected completely and appear under Protected cards. Checked premium types also count toward copies to keep." />
                    <Button HorizontalAlignment="Left" Content="Review and save rules" Command="{Binding SaveSettingsCommand}" />
                </StackPanel>
				</ScrollViewer>
            </TabItem>
        </TabControl>

        <Border Grid.Row="2" Background="{StaticResource PanelBrush}" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" Padding="8" Margin="0,8,0,0">
            <TextBlock Text="{Binding StatusMessage}" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
